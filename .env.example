# System Gemini API key for server-side orchestrator execution
# (Alternatively, judges/users can configure their own key dynamically in the UI)
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Port for the FastAPI server
PORT=8080
